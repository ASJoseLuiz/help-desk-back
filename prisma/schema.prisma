generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  hash_password   String
  role            Role     @default(CLIENT)
  createdAt       DateTime @default(now())
}
